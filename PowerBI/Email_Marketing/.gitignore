# ============================================================
# Power BI Files
# Large binary files — excluded from version control.
# Share dashboard screenshots instead of committing .pbix.
# ============================================================
*.pbix
*.pbit

# ============================================================
# Data Files — contains 10,000 customer records with PII
# (UUID, city, state, gender, DOB, marital status, living
# status). Excluded to protect customer data privacy.
# ============================================================
*.csv
*.xlsx
*.xlsm
*.xlsb
*.xls

# Excel lock/temp files
~$*.xlsx
~$*.xlsm
~$*.xls

# ============================================================
# Office documents
# ============================================================
*.docx
*.pptx
*.ppt
*.doc

# ============================================================
# Claude IDE config — local project settings, not for repo
# ============================================================
.claude/

# ============================================================
# OS & editor noise
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak
*.swp
